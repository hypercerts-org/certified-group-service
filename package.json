{
  "name": "group-service",
  "version": "0.2.0",
  "description": "Group-governed PDS for atproto",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.3.0",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "TSX_TSCONFIG_PATH=e2e/tsconfig.e2e.json node --import tsx/esm ./node_modules/@cucumber/cucumber/bin/cucumber-js --config e2e/cucumber.mjs",
    "e2e:app-password": "tsx e2e/support/app-password.ts",
    "typecheck": "tsc --project tsconfig.eslint.json",
    "lint": "eslint .",
    "lint:fix": "eslint --fix .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "changeset": "changeset",
    "version-packages": "changeset version && node scripts/changelog-audience-summary.mjs",
    "release": "changeset tag",
    "migrate": "tsx src/db/migrate.ts",
    "migrate:create": "tsx src/db/create-migration.ts"
  },
  "dependencies": {
    "@atproto/api": "^0.19.3",
    "@atproto/common-web": "^0.4.18",
    "@atproto/crypto": "^0.4.5",
    "@atproto/identity": "^0.4.12",
    "@atproto/lexicon": "^0.6.2",
    "@atproto/syntax": "^0.5.0",
    "@atproto/xrpc": "0.7.7",
    "@atproto/xrpc-server": "^0.10.15",
    "@ipld/dag-cbor": "^9.2.5",
    "better-sqlite3": "^11.0.0",
    "dotenv": "^16.4.0",
    "express": "^4.21.0",
    "kysely": "^0.27.0",
    "multiformats": "^13.4.2",
    "pino": "^9.0.0",
    "pino-http": "^10.0.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.5.0",
    "@changesets/cli": "^2.27.0",
    "@cucumber/cucumber": "^12.0.0",
    "@eslint/js": "^9.0.0",
    "@types/better-sqlite3": "^7.6.0",
    "@types/express": "^4.17.21",
    "@types/node": "^22.19.19",
    "@types/supertest": "^7.2.0",
    "@vitest/coverage-v8": "^2.1.9",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.3.0",
    "supertest": "^7.2.2",
    "tsx": "^4.19.0",
    "typescript": "^5.5.0",
    "typescript-eslint": "^8.0.0",
    "vitest": "^2.1.0"
  }
}
