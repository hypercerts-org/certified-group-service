# Smoke-test config for app.certified.group.import.
#
# Copy this file to  tests/smoke/.env  and fill in the values.
# This file is loaded ONLY by tests/smoke/import.ts — it is intentionally separate
# from the repo-root .env (real service config) and must never be merged into it.
# .env is gitignored, so the filled-in tests/smoke/.env is never committed.

# --- CGS under test ---
# The PR-30 Railway preview (already deployed):
CGS_URL=https://certified-group-service-certified-group-service-pr-30.up.railway.app

# The JWT `aud` must equal the CGS's configured serviceDid. By default the script
# derives it as did:web:<CGS_URL host>. Set this ONLY if the preview's SERVICE_URL
# points somewhere other than its own preview URL (e.g. inherited from `test`),
# in which case use did:web:<that SERVICE_URL host>.
# CGS_SERVICE_DID=did:web:certified-group-service-certified-group-service-pr-30.up.railway.app

# --- Owner account (becomes the group owner; must be able to mint a service-auth JWT) ---
# This script mints the JWT via password login (a smoke-test convenience — real
# callers use OAuth/getServiceAuth). OWNER_PASSWORD must be a real account
# password; ePDS accounts are OTP/OAuth-first, so set a password on the throwaway
# test owner account if it doesn't have one.
OWNER_PDS=https://pds.example.com
OWNER_IDENTIFIER=did:plc:xxxxxxxxxxxxxxxxxxxxxxxx
OWNER_PASSWORD=

# --- Account being imported (DID + an app password for it) ---
# Common case: this IS the owner account — then set IMPORT_DID = OWNER_IDENTIFIER
# (the owner's DID) and reuse its app password here.
IMPORT_DID=did:plc:xxxxxxxxxxxxxxxxxxxxxxxx
IMPORT_APP_PASSWORD=
