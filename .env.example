# Server
# Port the HTTP server listens on
PORT=3000

# Public hostname of this service (e.g. group-service.example.com)
PUBLIC_HOSTNAME=group-service.example.com

# Storage
# Directory where SQLite databases and group data are stored
DATA_DIR=/app/data

# Security
# 32-byte hex key used for AES-256-GCM encryption of stored credentials
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=

# Group PDS
# URL of the PDS where group accounts are created
GROUP_PDS_URL=https://pds.example.com

# atproto
# PLC directory URL
PLC_URL=https://plc.directory

# DID document cache TTL in milliseconds (default: 10 minutes)
DID_CACHE_TTL_MS=600000

# Blobs
# Maximum blob upload size in bytes (default: 5 MB)
MAX_BLOB_SIZE=5242880

# Logging
# Log level: trace, debug, info, warn, error, fatal
LOG_LEVEL=info
